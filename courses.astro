  <style>
    *, *::before, *::after { box-sizing: border-box; }
    body { font-family:'DM Sans',sans-serif; background:#0d0d0d; color:#f5f5f5; overflow-x:hidden; }
    h1,h2,h3,h4,.font-display { font-family:'Syne',sans-serif; }

    /* Grain */
    body::before {
      content:''; position:fixed; inset:0; z-index:0; pointer-events:none;
      background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
      opacity:.3;
    }

    /* Glass */
    .glass {
      background:rgba(255,255,255,0.04);
      border:1px solid rgba(255,255,255,0.09);
      backdrop-filter:blur(14px);
    }
    .glass-hover:hover {
      background:rgba(255,255,255,0.07);
      border-color:rgba(249,115,22,0.35);
    }

    /* Nav */
    .nav-blur { background:rgba(13,13,13,0.85); backdrop-filter:blur(20px); border-bottom:1px solid rgba(255,255,255,0.06); }

    /* Scroll reveal */
    .reveal { opacity:0; transform:translateY(24px); transition:opacity 0.65s ease, transform 0.65s ease; }
    .revealed { opacity:1; transform:translateY(0); }

    /* Stagger children */
    .stagger > * { opacity:0; transform:translateY(20px); transition:opacity 0.5s ease, transform 0.5s ease; }
    .stagger.revealed > *:nth-child(1) { opacity:1; transform:none; transition-delay:0ms; }
    .stagger.revealed > *:nth-child(2) { opacity:1; transform:none; transition-delay:100ms; }
    .stagger.revealed > *:nth-child(3) { opacity:1; transform:none; transition-delay:200ms; }
    .stagger.revealed > *:nth-child(4) { opacity:1; transform:none; transition-delay:300ms; }
    .stagger.revealed > *:nth-child(5) { opacity:1; transform:none; transition-delay:400ms; }

    /* CTA glow */
    .cta-glow:hover { box-shadow:0 0 28px rgba(249,115,22,0.5); }

    /* Course card border gradient on hover */
    .course-card {
      position:relative; border:1px solid rgba(255,255,255,0.08);
      transition:border-color 0.3s, transform 0.3s, box-shadow 0.3s;
    }
    .course-card:hover {
      border-color:rgba(249,115,22,0.4);
      transform:translateY(-4px);
      box-shadow:0 20px 60px rgba(0,0,0,0.5), 0 0 0 1px rgba(249,115,22,0.15);
    }
    .course-card .top-bar {
      position:absolute; top:0; left:0; right:0; height:3px;
      background:linear-gradient(90deg,#f97316,#fb923c);
      border-radius:16px 16px 0 0;
      opacity:0; transition:opacity 0.3s;
    }
    .course-card:hover .top-bar { opacity:1; }

    /* Badge pill */
    .badge { display:inline-flex; align-items:center; gap:6px; font-size:11px; font-weight:700; letter-spacing:.08em; text-transform:uppercase; padding:4px 10px; border-radius:100px; }

    /* Feature tick */
    .feat { display:flex; align-items:flex-start; gap:10px; }
    .feat-icon { width:18px; height:18px; border-radius:50%; background:rgba(249,115,22,0.15); display:flex; align-items:center; justify-content:center; flex-shrink:0; margin-top:2px; }

    /* Phase step */
    .phase-step { display:flex; gap:16px; align-items:flex-start; }
    .phase-num { width:36px; height:36px; border-radius:50%; background:rgba(249,115,22,0.12); border:1px solid rgba(249,115,22,0.3); display:flex; align-items:center; justify-content:center; flex-shrink:0; font-family:'Syne',sans-serif; font-weight:800; color:#f97316; font-size:13px; }

    /* Tabs */
    .tab-btn { transition:all 0.25s; }
    .tab-btn.active { background:rgba(249,115,22,0.12); color:#f97316; border-color:rgba(249,115,22,0.4); }
    .tab-panel { display:none; }
    .tab-panel.active { display:block; }

    /* Comparison table */
    .cmp-row:nth-child(even) { background:rgba(255,255,255,0.025); }

    /* Marquee */
    .marquee-wrap { overflow:hidden; }
    .marquee-inner { display:flex; width:max-content; animation:marquee 28s linear infinite; }

    /* Accent underline */
    .u-orange { text-decoration:underline; text-decoration-color:#f97316; text-underline-offset:5px; text-decoration-thickness:2px; }

    /* Hero mesh */
    .hero-bg {
      background:
        radial-gradient(ellipse 70% 60% at 10% 40%, rgba(249,115,22,0.14) 0%, transparent 65%),
        radial-gradient(ellipse 50% 70% at 90% 10%, rgba(249,115,22,0.08) 0%, transparent 60%),
        #0d0d0d;
    }
  </style>
</head>

